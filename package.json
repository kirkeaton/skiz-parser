{
  "name": "skiz-parser",
  "version": "0.0.0-development",
  "description": "Parse a .skiz file exported from Ski Tracks",
  "author": "Kirk Eaton <contact@kirkeaton.ca>",
  "bugs": {
    "url": "https://github.com/kirkeaton/skiz-parser/issues"
  },
  "dependencies": {
    "csv-parse": "6.2.1",
    "fast-xml-parser": "5.8.0",
    "yauzl": "3.3.2"
  },
  "devDependencies": {
    "@kirkeaton/prettier-config": "2.0.0",
    "@kirkeaton/tsconfig": "3.0.0",
    "@types/node": "25.9.3",
    "@types/yauzl": "2.10.3",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "funding": "https://kirkeaton.ca/sponsor",
  "homepage": "https://github.com/kirkeaton/skiz-parser#readme",
  "keywords": [
    "file",
    "parse",
    "ski tracks",
    "skiz"
  ],
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirkeaton/skiz-parser.git"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "format": "prettier \"**/*.{js,json,md,ts}\" --write",
    "lint": "prettier \"**/*.{js,json,md,ts}\" --check",
    "prepublishOnly": "npm run build",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
